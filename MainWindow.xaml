<Window x:Class="MSSLTeamsMessenger.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MSSLTeamsMessenger"
        mc:Ignorable="d"
        Title="MSSL Teams Messenger - DeJong United" Height="700" Width="1000"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="180"/>
        </Grid.RowDefinitions>

        <!-- LEFT PANEL: Alias List -->
        <DockPanel Grid.Column="0" Grid.Row="0" Margin="0,0,5,0">
            <TextBlock DockPanel.Dock="Top" Text="Aliases" FontWeight="Bold" FontSize="14" Margin="0,0,0,5"/>
            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,5">
                <Button Content="Select All" Click="SelectAll_Click" Padding="8,3" Margin="0,0,5,0"/>
                <Button Content="Deselect All" Click="DeselectAll_Click" Padding="8,3" Margin="0,0,5,0"/>
                <TextBlock x:Name="CountText" VerticalAlignment="Center" Margin="5,0,0,0" Foreground="Gray"/>
            </StackPanel>
            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,5">
                <Button Content="📋 Import from Clipboard" Click="ImportClipboard_Click" Padding="8,3" Margin="0,0,5,0"
                        Background="#5B2D8E" Foreground="White" FontSize="11"/>
                <Button Content="💾 Export to alias.txt" Click="ExportAliases_Click" Padding="8,3" Margin="0,0,5,0"
                        FontSize="11"/>
            </StackPanel>
            <DataGrid x:Name="AliasGrid" AutoGenerateColumns="False" CanUserAddRows="False"
                      HeadersVisibility="Column" IsReadOnly="False" SelectionMode="Single"
                      VerticalScrollBarVisibility="Auto">
                <DataGrid.Columns>
                    <DataGridCheckBoxColumn Header="✓" Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}" Width="35"/>
                    <DataGridTextColumn Header="Alias" Binding="{Binding Alias}" Width="130" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="*" IsReadOnly="True"/>
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>

        <!-- RIGHT PANEL -->
        <DockPanel Grid.Column="1" Grid.Row="0" Margin="5,0,0,0">
            <!-- Message -->
            <TextBlock DockPanel.Dock="Top" Text="Message" FontWeight="Bold" FontSize="14" Margin="0,0,0,5"/>
            <TextBox x:Name="MessageBox" DockPanel.Dock="Top" AcceptsReturn="True" TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto" Height="250" Margin="0,0,0,10"
                     FontFamily="Segoe UI" FontSize="13"/>

            <!-- Settings -->
            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,10">
                <TextBlock Text="Delay between messages (seconds):" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox x:Name="DelayBox" Width="50" Text="7" VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Buttons -->
            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,10">
                <Button x:Name="TestBtn" Content="🧪 Test (Send to mohaimenkhan)" Click="Test_Click"
                        Padding="12,6" Margin="0,0,8,0" FontSize="13" Background="#0078D4" Foreground="White"/>
                <Button x:Name="SendBtn" Content="📨 Send to Selected" Click="Send_Click"
                        Padding="12,6" Margin="0,0,8,0" FontSize="13" Background="#107C10" Foreground="White"/>
                <Button x:Name="StopBtn" Content="⛔ Stop" Click="Stop_Click"
                        Padding="12,6" FontSize="13" Background="#D83B01" Foreground="White" IsEnabled="False"/>
            </StackPanel>

            <!-- Progress -->
            <StackPanel DockPanel.Dock="Top">
                <ProgressBar x:Name="ProgressBar" Height="20" Margin="0,0,0,5" Minimum="0"/>
                <TextBlock x:Name="ProgressText" Foreground="Gray"/>
            </StackPanel>
        </DockPanel>

        <!-- BOTTOM: Log -->
        <DockPanel Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="1" Margin="0,5,0,0">
            <TextBlock DockPanel.Dock="Top" Text="Log" FontWeight="Bold" FontSize="14" Margin="0,0,0,5"/>
            <ListBox x:Name="LogList" FontFamily="Consolas" FontSize="11"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"/>
        </DockPanel>
    </Grid>
</Window>
